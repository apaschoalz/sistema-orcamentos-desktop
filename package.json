{
  "name": "entre-tramas-orcamentos",
  "version": "1.3.8",
  "description": "Sistema de Orçamentos Entre Tramas - Desktop App",
  "author": "Entre Tramas Interiores",
  "repository": {
    "type": "git",
    "url": "https://github.com/apaschoalz/sistema-orcamentos-desktop.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "electron": "electron .",
    "build": "npm run react-build && electron-builder",
    "build:win": "npm run react-build && electron-builder --win",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "qa": "node tests/run-qa.js",
    "qa:report": "npx playwright show-report tests/e2e/report"
  },
  "build": {
    "appId": "com.entretramas.orcamentos",
    "productName": "Entre Tramas - Orçamentos",
    "publish": [
      {
        "provider": "github",
        "owner": "apaschoalz",
        "repo": "sistema-orcamentos-desktop"
      }
    ],
    "extends": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "logo.jpg",
      "assets/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "entre-tramas-orcamentos-setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  },
  "homepage": "./",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "better-sqlite3": "^9.2.2",
    "chart.js": "^4.5.1",
    "electron-updater": "^6.8.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "pdfkit": "^0.17.2",
    "pdfmake": "^0.3.3",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "playwright-electron": "^0.5.0",
    "react-scripts": "5.0.1",
    "typescript": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      "last 1 electron version"
    ],
    "development": [
      "last 1 electron version"
    ]
  }
}
